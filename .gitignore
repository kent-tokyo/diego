# =============================================================================
# Rust build artifacts
# =============================================================================
/target/

# Note: Cargo.lock is intentionally NOT ignored for binaries.
# It ensures reproducible builds and should be committed.

# =============================================================================
# IDE and editor files
# =============================================================================
.idea/
.vscode/
*.iml

# =============================================================================
# macOS system files
# =============================================================================
.DS_Store
.AppleDouble
.LSOverride

# =============================================================================
# Editor backup and swap files
# =============================================================================
*~
*.swp
*.swo

# =============================================================================
# Environment variables and secrets
# =============================================================================
.env
.env.*
*.key
*.pem
*.p12
*.pfx

# =============================================================================
# Claude Code internal files
# =============================================================================
.claude/

# =============================================================================
# Test and scan output files
# =============================================================================
# JSON output from security scans
*.scan.json
scan_results*.json
output*.json
report*.json
# but keep the committed report JSON Schema (a docs artifact, not a scan output)
!docs/report.schema.json

# Markdown reports generated by scans
scan_results*.md
report*.md
output*.md
